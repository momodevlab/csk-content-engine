# ============================================================
# CSK Tech Solutions — Content Engine Environment Variables
# Copy to .env and fill in your values. Never commit .env.
# ============================================================

# --- Anthropic (content creation) ---
ANTHROPIC_API_KEY=your_anthropic_api_key

# --- Reddit (idea scraping) ---
# Register at: reddit.com/prefs/apps → create app → script type
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=CSKContentBot/1.0

# --- YouTube Data API (idea scraping) ---
# Enable at: console.cloud.google.com → YouTube Data API v3
YOUTUBE_API_KEY=your_youtube_api_key

# --- Twitter/X (scraping + posting) ---
# Apply at: developer.twitter.com
TWITTER_BEARER_TOKEN=your_twitter_bearer_token

# --- Perplexity (story research context) ---
PERPLEXITY_API_KEY=your_perplexity_api_key

# --- Canva (carousel generation) ---
CANVA_API_KEY=your_canva_api_key

# --- GoHighLevel (publishing + newsletter) ---
# Private Integration token from your GHL sub-account
GHL_API_KEY=your_ghl_private_integration_token
GHL_LOCATION_ID=your_ghl_location_id
GHL_LINKEDIN_ACCOUNT_ID=your_ghl_linkedin_social_account_id
GHL_FROM_EMAIL=newsletter@csktech.solutions
GHL_REPLY_TO_EMAIL=hello@csktech.solutions

# --- Slack ---
# Create app at: api.slack.com/apps
# Required scopes: chat:write, reactions:read, channels:history
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_APPROVAL_CHANNEL_ID=your_content_approval_channel_id
SLACK_NEWS_CHANNEL_ID=your_ai_news_feed_channel_id
SLACK_PERFORMANCE_CHANNEL_ID=your_content_performance_channel_id
SLACK_WORKSPACE_OWNER_ID=your_slack_user_id

# --- HeyGen (AI avatar video) ---
# Get at: heygen.com → Settings → API
HEYGEN_API_KEY=your_heygen_api_key
# After recording your Digital Twin:
HEYGEN_AVATAR_ID=your_avatar_id
HEYGEN_VOICE_ID=your_voice_id

# --- OpenAI (Whisper captions only) ---
OPENAI_API_KEY=your_openai_api_key

# --- Cloudinary (video URL hosting for platform APIs) ---
# Free tier works fine. cloudinary.com
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# --- YouTube Upload ---
# OAuth2 credentials from console.cloud.google.com
YOUTUBE_CLIENT_ID=your_yt_oauth_client_id
YOUTUBE_CLIENT_SECRET=your_yt_oauth_client_secret
YOUTUBE_REFRESH_TOKEN=your_yt_refresh_token

# --- Instagram (Graph API) ---
# Requires Facebook Business account + Instagram Professional account
INSTAGRAM_USER_ID=your_instagram_user_id
INSTAGRAM_ACCESS_TOKEN=your_long_lived_access_token
